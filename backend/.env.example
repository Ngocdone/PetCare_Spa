PORT=3001
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=petcare_spa
# Đồng bộ với phpMyAdmin / database/petcare_spa_vi.sql
# CORS_ORIGIN=http://localhost:5173
# Khi serve SPA build từ Node, khớp Vite base (mặc định):
# SPA_PUBLIC_BASE=/webSPA/PetCare_Spa

# Đăng nhập Google — cùng giá trị với VITE_GOOGLE_CLIENT_ID (OAuth 2.0 Web Client ID)
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# --- VNPay (sandbox / production) — https://sandbox.vnpayment.vn/apis/docs/huong-dan-tich-hop ---
# VNP_TMN_CODE=Mã website (Terminal ID)
# VNP_HASH_SECRET=Chuỗi bí mật ký giao dịch
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# URL cổng gọi lại sau thanh toán (phải trùng đăng ký trên portal VNPay; trỏ về backend Node)
# VNP_RETURN_URL=http://127.0.0.1:3001/api/payment/vnpay/return
# Trang SPA sau khi backend redirect (không có dấu / cuối; thêm path nếu deploy subfolder)
# FRONTEND_URL=http://127.0.0.1:5173
# IPN (tùy chọn, đăng ký trên VNPay): https://your-domain/api/payment/vnpay/ipn
