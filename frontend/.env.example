# Mặc định: Vite proxy `/api` → Express (cd backend && npm start), cùng MySQL.
# Nếu 502: kiểm tra backend chạy cổng 3001 và VITE_API_PROXY_TARGET.

# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Dev: code mặc định gọi thẳng http://127.0.0.1:3001 (không qua proxy). Đổi cổng API:
# VITE_API_BASE=http://127.0.0.1:4000

# Build production — URL API Node (không dấu / cuối), ví dụ cùng host:
# VITE_API_BASE=http://localhost:3001

# Đăng nhập Google (GIS) — cùng Client ID với GOOGLE_CLIENT_ID ở backend/.env
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:5173 và URL production của SPA
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Chỉ khi muốn dùng lại PHP trên Apache thay vì Node — đặt một trong hai:
# VITE_LEGACY_HTML_BASE=http://localhost/webSPA/PetCare_Spa
# VITE_PHP_PROXY=http://127.0.0.1/webSPA/PetCare_Spa
